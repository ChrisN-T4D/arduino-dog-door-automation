# Copy to .env on the Pi and `source` before starting, or use EnvironmentFile= in systemd.
# Do not commit .env (see root .gitignore).

export DOG_DOOR_SERIAL=/dev/ttyACM0
export DOG_DOOR_BAUD=9600
# Required: at least 10 characters, not a common default (unless DOG_DOOR_DEVELOPMENT=1).
export DOG_DOOR_PASSWORD=use-a-strong-unique-password-here
export DOG_DOOR_HTTP_HOST=0.0.0.0
export DOG_DOOR_HTTP_PORT=8080
export DOG_DOOR_HEARTBEAT_SEC=25
# Set to 1 only for local dev: short password ok, /docs enabled, empty password allowed (insecure).
# export DOG_DOOR_DEVELOPMENT=0
# Optional: database directory (default: pi/data/)
# export DOG_DOOR_DATA_DIR=/home/pi/dog-door-data

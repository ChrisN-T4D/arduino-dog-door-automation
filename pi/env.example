# Copy to .env on the Pi. Do not commit .env (see root .gitignore).
#
# Format: plain KEY=value (no leading "export"). Required for systemd EnvironmentFile=.
# For manual shell: from pi/ run  set -a && source .env && set +a  then uvicorn ...

DOG_DOOR_SERIAL=/dev/ttyACM0
DOG_DOOR_BAUD=9600
# Required: at least 10 characters, not a common default (unless DOG_DOOR_DEVELOPMENT=1).
DOG_DOOR_PASSWORD=use-a-strong-unique-password-here
DOG_DOOR_HTTP_HOST=0.0.0.0
DOG_DOOR_HTTP_PORT=8080
# Set to 1 only for local dev: short password ok, /docs enabled, empty password allowed (insecure).
# DOG_DOOR_DEVELOPMENT=0
# Optional: database directory (default: pi/data/)
# DOG_DOOR_DATA_DIR=/home/pi/dog-door-data

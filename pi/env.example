# Copy to env file on the Pi and `source` before starting, or use Environment= in systemd.
export DOG_DOOR_SERIAL=/dev/ttyACM0
export DOG_DOOR_BAUD=9600
export DOG_DOOR_PASSWORD=use-a-strong-password
export DOG_DOOR_HTTP_HOST=0.0.0.0
export DOG_DOOR_HTTP_PORT=8080
export DOG_DOOR_HEARTBEAT_SEC=25
# Optional: database directory (default: pi/data/)
# export DOG_DOOR_DATA_DIR=/home/pi/dog-door-data

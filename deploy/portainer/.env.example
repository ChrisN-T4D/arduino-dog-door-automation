# Copy values into Portainer → Stack → Environment variables (or use a .env file on the host).

# Home Assistant config directory on the host (recommended):
# HA_CONFIG_PATH=/srv/homeassistant
# Or omit to use the named volume `ha_config` from the compose file.

TZ=America/Chicago

# --- Traefik (external network must exist: docker network create traefik_proxy)
# Public hostname = HA_SUBDOMAIN + "." + TRAEFIK_DOMAIN_SUFFIX (e.g. ha + your zone).
# Set TRAEFIK_DOMAIN_SUFFIX to your private zone (the part you do not want hardcoded in git).
TRAEFIK_DOMAIN_SUFFIX=
HA_SUBDOMAIN=ha
TRAEFIK_CERT_RESOLVER=le

# Alternative: set a single FQDN and replace the rule in docker-compose.yml with:
#   traefik.http.routers.homeassistant.rule: "Host(`${HA_TRAEFIK_FQDN}`)"
# HA_TRAEFIK_FQDN=

# Eufy Security WebSocket bridge — enable stack profile `eufy` (see README).
# COMPOSE_PROFILES=eufy
# EUFY_USERNAME=
# EUFY_PASSWORD=
# EUFY_COUNTRY=US
# EUFY_LANGUAGE=en

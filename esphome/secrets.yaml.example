# Rename to secrets.yaml (never commit secrets.yaml).

wifi_ssid: "your-ssid"
wifi_password: "your-wifi-password"

# Generate: openssl rand -base64 32  (each ESPHome device should have its own key)
api_encryption_key: "REPLACE_WITH_32_CHAR_BASE64"

# Used by dog_door_uno_bridge.yaml (ESP ↔ Uno); use a different value than api_encryption_key
api_encryption_key_bridge: "REPLACE_WITH_32_CHAR_BASE64"

# Outdoor mmWave ESP (dog_door_mmwave_outdoor.yaml); distinct from api_encryption_key
api_encryption_key_mm_outdoor: "REPLACE_WITH_32_CHAR_BASE64"
